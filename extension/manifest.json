{
    "manifest_version": 3,
    "name": "Recallify",
    "version": "1.0",
    "description": "Recallify — Learn directly from the web with AI-powered flashcards.",
    "permissions": [
        "contextMenus",
        "storage",
        "notifications"
    ],
    "host_permissions": [
        "https://generativelanguage.googleapis.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Recallify"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "recallify@example.com",
            "strict_min_version": "109.0"
        }
    }
}